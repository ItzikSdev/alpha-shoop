# Copy to .env and fill in real values:  cp .env.example .env

# ── Anthropic ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── LiteLLM Proxy ────────────────────────────────────────────────────────────
LITELLM_PROXY_URL=http://localhost:4000
LITELLM_MASTER_KEY=alpha-shoop-local

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/alphashoop
POSTGRES_PASSWORD=postgres
REDIS_URL=redis://localhost:6379/0
TRACES_DB_PATH=./data/traces.db

# ── Shopify Dev Store ─────────────────────────────────────────────────────────
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_ACCESS_TOKEN=shpat_...
SHOPIFY_WEBHOOK_SECRET=

# ── CJ Dropshipping ───────────────────────────────────────────────────────────
CJ_EMAIL=your@email.com
CJ_API_KEY=
CJ_MCP_KEY=

# ── Google Ads ────────────────────────────────────────────────────────────────
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=

# ── GCP (production / CI) ─────────────────────────────────────────────────────
GCP_PROJECT_ID=
GCP_REGION=us-central1

# ── Guardrails ────────────────────────────────────────────────────────────────
MAX_AD_SPEND_DAILY_USD=500
MAX_ORDER_VALUE_USD=200
