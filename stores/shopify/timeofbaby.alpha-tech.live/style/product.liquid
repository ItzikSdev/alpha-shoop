{%- assign v0 = product.selected_or_first_available_variant -%}
<div class="tobp">
  <div class="tobp-gallery">
    <div class="tobp-thumbs">
      {%- for media in product.media limit: 6 -%}
        <img src="{{ media | image_url: width: 140 }}" data-full="{{ media | image_url: width: 1200 }}"
             class="tobp-thumb{% if forloop.first %} active{% endif %}" alt="{{ product.title | escape }}">
      {%- endfor -%}
    </div>
    <div class="tobp-main">
      <img id="tobp-main-img" src="{{ product.featured_media | image_url: width: 1200 }}" alt="{{ product.title | escape }}">
    </div>
  </div>

  <div class="tobp-info">
    {%- if product.tags contains 'new' or product.available -%}<span class="tobp-tag">JUST LANDED</span>{%- endif -%}
    <div class="tobp-brand">{{ product.vendor | default: 'TIMEOF BABY' }}</div>
    <h1 class="tobp-title">{{ product.title }}</h1>

    <div class="tobp-price">
      <span id="tobp-price">{{ v0.price | money }}</span>
      {%- if product.compare_at_price > product.price -%}
        <s id="tobp-cmp">{{ product.compare_at_price | money }}</s>
        <span class="tobp-disc">{{ product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price }}% OFF</span>
      {%- endif -%}
    </div>

    {%- for opt in product.options_with_values -%}
      {%- unless opt.name == 'Title' and opt.values.size == 1 -%}
      <div class="tobp-opt">
        <div class="tobp-opt-label">{{ opt.name }}{% if opt.name == 'Size' %} &nbsp;<a href="#" class="tobp-sizechart" onclick="document.getElementById('tobp-sizemodal').classList.add('open');return false;">Size chart</a>{% endif %}</div>
        <div class="tobp-opt-values" data-opt="{{ forloop.index0 }}">
          {%- for val in opt.values -%}
            <button type="button" class="tobp-val{% if val == opt.selected_value %} active{% endif %}" data-opt="{{ forloop.parentloop.index0 }}" data-val="{{ val | escape }}">{{ val }}</button>
          {%- endfor -%}
        </div>
      </div>
      {%- endunless -%}
    {%- endfor -%}

    {%- form 'product', product -%}
      <input type="hidden" name="id" id="tobp-vid" value="{{ v0.id }}">
      <button type="submit" class="tobp-atc" id="tobp-atc">Add to cart</button>
    {%- endform -%}

    <div class="tobp-badges">✓ Free shipping on all orders &nbsp;·&nbsp; ✓ 30-day easy returns &nbsp;·&nbsp; ✓ Satisfaction guaranteed</div>
    <div class="tobp-desc">{{ product.description }}</div>
  </div>
</div>

<script>
/* record this product as "recently viewed" for the homepage section */
(function(){try{var p={n:{{ product.title | json }},i:{{ product.featured_image | image_url: width: 600 | json }},pr:{{ product.price | money | json }},u:{{ product.url | json }}};
var r=JSON.parse(localStorage.getItem("tob_recent_v2")||"[]");r=r.filter(function(x){return x.u!==p.u;});r.unshift(p);
localStorage.setItem("tob_recent_v2",JSON.stringify(r.slice(0,8)));}catch(e){}})();
</script>
<script>
(function(){
  var variants = {{ product.variants | json }};
  var optionCount = {{ product.options.size }};
  var sel = {};
  document.querySelectorAll('.tobp-val.active').forEach(function(b){ sel[b.dataset.opt] = b.dataset.val; });
  function fmt(c){ return '$' + (c/100).toFixed(2); }
  function match(){
    return variants.find(function(v){
      for (var i=0;i<optionCount;i++){ if (v.options[i] !== sel[i]) return false; }
      return true;
    });
  }
  function refresh(){
    var v = match();
    var atc = document.getElementById('tobp-atc');
    if (v){
      document.getElementById('tobp-vid').value = v.id;
      document.getElementById('tobp-price').textContent = fmt(v.price);
      atc.disabled = !v.available; atc.textContent = v.available ? 'Add to cart' : 'Sold out';
    }
  }
  document.querySelectorAll('.tobp-val').forEach(function(btn){
    btn.addEventListener('click', function(){
      var o = btn.dataset.opt;
      document.querySelectorAll('.tobp-val[data-opt="'+o+'"]').forEach(function(b){ b.classList.remove('active'); });
      btn.classList.add('active'); sel[o] = btn.dataset.val; refresh();
    });
  });
  document.querySelectorAll('.tobp-thumb').forEach(function(t){
    function swap(e){ if(e){e.preventDefault();}
      var mi=document.getElementById('tobp-main-img');
      mi.src = t.dataset.full;
      document.querySelectorAll('.tobp-thumb').forEach(function(x){ x.classList.remove('active'); });
      t.classList.add('active');
      if(window.innerWidth<820){ mi.scrollIntoView({behavior:'smooth',block:'center'}); }
    }
    t.addEventListener('click', swap);
    t.addEventListener('touchend', swap);
  });
})();
</script>

<!--TOBP_SIZECHART-->

<style>
  .tobp{--ink:#161616;--muted:#8d8d8d;--line:#e7e7e7;--soft:#f6f4f1;font-family:-apple-system,"Helvetica Neue",Inter,Arial,sans-serif;color:var(--ink);max-width:1240px;margin:0 auto;padding:30px 28px;display:grid;grid-template-columns:1.1fr .9fr;gap:48px}
  .tobp *{box-sizing:border-box}
  .tobp-gallery{display:flex;gap:14px}
  .tobp-thumbs{display:flex;flex-direction:column;gap:10px}
  .tobp-thumb{width:70px;height:90px;object-fit:cover;border:1px solid var(--line);cursor:pointer;opacity:.7;transition:.2s}
  .tobp-thumb.active,.tobp-thumb:hover{opacity:1;border-color:var(--ink)}
  .tobp-main{flex:1;background:var(--soft)}
  .tobp-main img{width:100%;aspect-ratio:4/5;object-fit:cover;display:block}
  .tobp-tag{display:inline-block;background:#161616;color:#fff;font-size:var(--tobp-tag,.92rem);letter-spacing:.12em;text-transform:uppercase;padding:7px 14px;font-weight:700;margin-bottom:14px}
  .tobp-brand{font-size:var(--tobp-brand,1.1rem);letter-spacing:.12em;text-transform:uppercase;color:var(--muted);font-weight:600}
  .tobp-title{font-size:var(--tobp-title,3rem);font-weight:500;margin:8px 0 20px;letter-spacing:-.01em}
  .tobp-price{display:flex;align-items:center;gap:12px;margin-bottom:26px}
  .tobp-price #tobp-price{font-size:var(--tobp-price,2.6rem);font-weight:700}
  .tobp-price s{color:var(--muted);font-size:var(--tobp-compare,1.6rem)}
  .tobp-disc{background:#161616;color:#fff;font-size:var(--tobp-disc,1.05rem);font-weight:700;padding:5px 12px;letter-spacing:.05em}
  .tobp-modal{position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:100;display:none;align-items:center;justify-content:center;padding:20px}
  .tobp-modal.open{display:flex}
  .tobp-modal-box{background:#fff;max-width:540px;width:100%;max-height:85vh;overflow:auto;padding:34px;position:relative}
  .tobp-modal-box h3{font-size:1.7rem;font-weight:600;margin-bottom:4px}
  .tobp-modal-box .sub{color:#8d8d8d;margin-bottom:22px;font-size:.95rem}
  .tobp-modal-box table{width:100%;border-collapse:collapse}
  .tobp-modal-box th,.tobp-modal-box td{padding:12px 8px;border-bottom:1px solid #eee;text-align:center;font-size:1.02rem}
  .tobp-modal-box th{text-transform:uppercase;font-size:.78rem;letter-spacing:.08em;color:#8d8d8d}
  .tobp-modal-close{position:absolute;top:16px;right:18px;cursor:pointer;font-size:1.8rem;line-height:1;border:none;background:none;color:#161616}
  .tobp-opt{margin-bottom:22px}
  .tobp-opt-label{font-size:var(--tobp-optlabel,1.15rem);letter-spacing:.06em;text-transform:uppercase;color:var(--muted);font-weight:600;margin-bottom:10px}
  .tobp-sizechart{color:var(--ink);text-decoration:underline;text-transform:none;letter-spacing:0}
  .tobp-opt-values{display:flex;flex-wrap:wrap;gap:10px}
  .tobp-val{min-width:74px;padding:15px 20px;border:1px solid var(--line);background:#fff;font-size:var(--tobp-optbtn,1.25rem);font-weight:600;cursor:pointer;transition:.15s}
  .tobp-val:hover{border-color:var(--ink)}
  .tobp-val.active{background:#161616;color:#fff;border-color:#161616}
  .tobp-atc{width:100%;background:#161616;color:#fff;border:none;padding:19px;font-size:.92rem;font-weight:700;text-transform:uppercase;letter-spacing:.08em;cursor:pointer;transition:.2s;margin-top:6px}
  .tobp-atc:hover{opacity:.88}
  .tobp-atc:disabled{background:var(--muted);cursor:not-allowed}
  .tobp-badges{margin:22px 0;font-size:var(--tobp-badge,1.1rem);color:#555;border-top:1px solid var(--line);border-bottom:1px solid var(--line);padding:16px 0}
  .tobp-desc{font-size:var(--tobp-desc,1.25rem);line-height:1.7;color:#444}
  .tobp-desc ul{padding-left:18px;margin:10px 0}
  @media(max-width:820px){
    .tobp{grid-template-columns:1fr;gap:20px;padding:16px 16px 48px}
    .tobp-gallery{flex-direction:column-reverse;gap:10px}
    .tobp-thumbs{flex-direction:row;overflow-x:auto;-webkit-overflow-scrolling:touch;scrollbar-width:none}
    .tobp-thumbs::-webkit-scrollbar{display:none}
    .tobp-thumb{width:54px;height:70px;flex:0 0 auto}
    .tobp-main img{aspect-ratio:1/1;max-height:60vh}
    .tobp-tag{font-size:.7rem;margin-bottom:10px}
    .tobp-brand{font-size:.82rem}
    .tobp-title{font-size:1.65rem;margin:6px 0 14px}
    .tobp-price{gap:10px;margin-bottom:20px}
    .tobp-price #tobp-price{font-size:1.85rem}
    .tobp-price s{font-size:1.15rem}
    .tobp-disc{font-size:.82rem;padding:4px 9px}
    .tobp-opt{margin-bottom:18px}
    .tobp-opt-label{font-size:.92rem;margin-bottom:8px}
    .tobp-opt-values{gap:8px}
    .tobp-val{min-width:0;flex:1 1 22%;padding:13px 8px;font-size:1rem;text-align:center}
    .tobp-atc{padding:17px;font-size:.9rem}
    .tobp-badges{margin:18px 0;font-size:.82rem;padding:13px 0}
    .tobp-desc{font-size:1rem}
  }
</style>

{% schema %}
{"name":"TimeOf Product","settings":[],"presets":[{"name":"TimeOf Product"}]}
{% endschema %}
