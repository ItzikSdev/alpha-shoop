        <UserObject label="" mermaidData="{&#xa;  &quot;data&quot;: &quot;graph TB\n    %% סגנונות ועיצובים\n    classDef llmZone fill:#f9fbfd,stroke:#338333,stroke-width:2px;\n    classDef mcpZone fill:#f5f6fa,stroke:#2f3640,stroke-width:2px;\n    classDef apiZone fill:#fff5f5,stroke:#c23616,stroke-width:2px;\n    \n    %% שכבת ה-Client / AI\n    subgraph Client_Layer [\&quot;שכבת ה-AI / Client\&quot;]\n        A[Claude Desktop / LangGraph Client]\n    end\n    class Client_Layer llmZone;\n\n    %% שכבת ה-MCP Server\n    subgraph MCP_Server [\&quot;E-commerce Arbitrage MCP Server\&quot;]\n        B[MCP Protocol Engine &lt;br&gt; Stdio / SSE Transport]\n        \n        subgraph Tools_Registry [\&quot;Tools Registry (JSON Schemas)\&quot;]\n            T1[\&quot;1. Sourcing Tools&lt;br&gt;• search_trending_products&lt;br&gt;• get_shipping_cost\&quot;]\n            T2[\&quot;2. Market Validation Tools&lt;br&gt;• search_market_prices&lt;br&gt;• check_google_trends\&quot;]\n            T3[\&quot;3. Shopify Tools&lt;br&gt;• create_shopify_product&lt;br&gt;• update_inventory\&quot;]\n            T4[\&quot;4. Ads Tools&lt;br&gt;• create_google_campaign&lt;br&gt;• get_campaign_metrics\&quot;]\n            T5[\&quot;5. Fulfillment Tools&lt;br&gt;• place_supplier_order&lt;br&gt;• fulfill_shopify_order\&quot;]\n        end\n        \n        C[Secure Context &amp; Environment Config&lt;br&gt;• API Keys Locked Inside Server •]\n    end\n    class MCP_Server mcpZone;\n\n    %% שכבת ה-APIs החיצוניים\n    subgraph External_APIs [\&quot;עולם חיצוני (External APIs)\&quot;]\n        E1[Supplier APIs &lt;br&gt; CJ / AliExpress]\n        E2[Market Data APIs &lt;br&gt; Google Shopping / Trends]\n        E3[Shopify Admin GraphQL API]\n        E4[Google / Meta Ads API]\n    end\n    class External_APIs apiZone;\n\n    %% זרימת הנתונים והתקשורת (Data Flow)\n    A &lt;--&gt; |\&quot;1. list_tools() &amp; call_tool()&lt;br&gt;(No API Keys Exposes)\&quot;| B\n    B --&gt; T1 &amp; T2 &amp; T3 &amp; T4 &amp; T5\n    \n    %% חיבור הכלים ל-APIs האמיתיים עם ה-Keys המוגנים\n    C -.-&gt; T1 &amp; T2 &amp; T3 &amp; T4 &amp; T5\n    \n    T1 &lt;--&gt; |\&quot;REST / JSON\&quot;| E1\n    T2 &lt;--&gt; |\&quot;REST / Serper\&quot;| E2\n    T3 &lt;--&gt; |\&quot;GraphQL (Admin Token)\&quot;| E3\n    T4 &lt;--&gt; |\&quot;gRPC / REST\&quot;| E4\n    T5 &lt;--&gt; |\&quot;Secure Webhooks / Post\&quot;| E1 &amp; E3&quot;,&#xa;  &quot;config&quot;: null&#xa;}" id="uI5UBBW1wjnPFzFWvCIV-1">
